.stats-grid { display: flex; justify-content: space-between; margin-bottom: 24rpx; }
.stat-card { flex: 1; background-color: #ffffff; border-radius: 16rpx; padding: 30rpx 16rpx; text-align: center; margin: 0 6rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); }
.stat-card:first-child { margin-left: 0; }
.stat-card:last-child { margin-right: 0; }
.stat-num { font-size: 48rpx; font-weight: 700; color: var(--theme-primary); }
.stat-label { font-size: 24rpx; color: #999999; margin-top: 8rpx; }
.card-title { font-size: 32rpx; font-weight: 600; color: #333333; margin-bottom: 24rpx; }
.record-list { display: flex; flex-direction: column; }
.record-item { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.record-item:last-child { border-bottom: none; }
.student-info { display: flex; align-items: center; }
.avatar { width: 56rpx; height: 56rpx; border-radius: 50%; background: linear-gradient(135deg, var(--theme-primary) 0%, var(--theme-dark) 100%); color: var(--theme-text); font-size: 24rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; margin-right: 16rpx; }
.info { display: flex; flex-direction: column; }
.name { font-size: 28rpx; color: #333333; }
.desc { font-size: 24rpx; color: #999999; margin-top: 4rpx; }
.score-badge { padding: 8rpx 16rpx; border-radius: 20rpx; font-size: 24rpx; font-weight: 600; background-color: #E6FFF2; color: #52c41a; }

