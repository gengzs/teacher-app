/* 班级详情页样式 */
.container {
  min-height: 100vh;
  background: var(--theme-light);
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 班级头部 */
.class-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.class-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 500;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.class-info {
  flex: 1;
  min-width: 0;
}

.class-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.class-count {
  font-size: 26rpx;
  color: #999;
}

.invite-code-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 20rpx;
  background: var(--theme-gradient);
  border-radius: 12rpx;
  min-width: 100rpx;
}

.invite-code-box:active {
  opacity: 0.7;
  transform: scale(0.97);
}

.invite-label {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.invite-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--theme-accent);
  letter-spacing: 2rpx;
}

/* 功能模块入口 */
.module-grid {
  margin-bottom: 20rpx;
}

.module-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.module-card.request {
  background: linear-gradient(135deg, #FFF7E6 0%, #FFF1DB 100%);
}

/* 班级成员整合卡片 */
.members-card {
  flex-direction: column;
  align-items: stretch;
}

.members-header {
  display: flex;
  align-items: center;
}

.members-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.member-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
  background: var(--theme-gradient);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: var(--theme-accent);
  font-weight: 500;
}

.member-btn:active {
  opacity: 0.85;
}

.member-badge {
  background: #ff4d4f;
  color: #fff;
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  font-weight: normal;
}

.module-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.module-content {
  flex: 1;
}

.module-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.module-desc {
  font-size: 24rpx;
  color: #999;
}

.module-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.badge {
  background: #ff4d4f;
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* 待审核角标 */
.pending-badge {
  display: inline-block;
  background: #ff4d4f;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
  font-weight: normal;
}

/* 区块标题 */
.section {
  margin-bottom: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: var(--theme-accent);
}

/* 操作卡片行 */
.action-row {
  display: flex;
  gap: 16rpx;
}

.action-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  text-align: center;
}

.action-card.primary {
  background: var(--theme-gradient);
  color: var(--theme-accent);
}

.action-card.primary .action-desc {
  color: rgba(255, 255, 255, 0.8);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-title {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.action-desc {
  font-size: 24rpx;
  color: #999;
}

/* 最近作业列表 */
.homework-list {
  margin-top: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.homework-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.homework-item:last-child {
  border-bottom: none;
}

.homework-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.homework-info {
  flex: 1;
}

.homework-title {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.homework-meta {
  font-size: 24rpx;
  color: #999;
}

.homework-progress {
  text-align: right;
}

.progress-text {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--theme-accent);
}

.progress-label {
  font-size: 22rpx;
  color: #999;
}

/* 统计数据行 */
.stats-row {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-item:first-child {
  border-right: 1rpx solid #f0f0f0;
}

.stat-item:last-child {
  border-left: 1rpx solid #f0f0f0;
}

.stat-value {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: var(--theme-accent);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* ========== 弹窗样式 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 100;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 101;
}

.modal.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
}

/* 表单 */
.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-input {
  height: 80rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.form-hint {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  background: var(--theme-light);
  border-radius: 12rpx;
  margin-bottom: 30rpx;
}

.hint-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.hint-text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* 弹窗底部按钮 */
.modal-footer {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #f5f5f5;
  color: #666;
  font-size: 30rpx;
  border-radius: 40rpx;
}

.btn-confirm {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: var(--theme-gradient);
  color: var(--theme-accent);
  font-size: 30rpx;
  border-radius: 40rpx;
}

.btn-confirm.loading {
  opacity: 0.6;
}

.btn-secondary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: var(--theme-gradient);
  color: var(--theme-accent);
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* 添加成功结果 */
.result-body {
  text-align: center;
}

.result-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
}

.result-info {
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  text-align: left;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.info-label {
  font-size: 28rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  color: #333;
}

.info-value.highlight {
  color: var(--theme-accent);
  font-weight: 600;
  letter-spacing: 4rpx;
}

.result-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.tip-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #ff9800;
}

/* 自定义 TabBar 占位 */
.container {
  /* padding-bottom 已通过 style 属性在 wxml 中处理 */
}
