/* 班级资料库页面样式 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 搜索栏 */
.search-bar {
  position: relative;
  margin-bottom: 20rpx;
}

.search-input {
  height: 80rpx;
  padding: 0 80rpx 0 30rpx;
  background: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.search-icon {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
}

/* 分类标签 */
.category-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.category-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0;
}

.category-item {
  padding: 12rpx 32rpx;
  background: #fff;
  border-radius: 28rpx;
  font-size: 28rpx;
  color: #666;
  white-space: nowrap;
}

.category-item.active {
  background: var(--theme-accent);
  color: #fff;
}

/* 操作栏 */
.action-bar {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.action-btn {
  padding: 10rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: var(--theme-accent);
  margin-right: 16rpx;
}

.selection-count {
  margin-left: auto;
  font-size: 26rpx;
  color: #999;
}

/* 文章列表 */
.article-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.article-item {
  display: flex;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.article-item:last-child {
  border-bottom: none;
}

.article-item.selected {
  background: var(--theme-light);
}

.article-checkbox {
  padding-right: 20rpx;
  padding-top: 4rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.checkbox.checked {
  background: var(--theme-accent);
  border-color: var(--theme-accent);
  color: #fff;
}

.article-content {
  flex: 1;
}

.article-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.article-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
}

.article-meta {
  display: flex;
  gap: 12rpx;
  margin-left: 16rpx;
}

.level {
  font-size: 24rpx;
  color: #ff9800;
}

.word-count {
  font-size: 24rpx;
  color: #999;
}

.article-preview {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.article-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.category-tag {
  padding: 4rpx 16rpx;
  background: #f0f0f0;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #666;
}

.duration {
  font-size: 24rpx;
  color: #999;
}

/* 底部发送按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  transform: translateY(100%);
  transition: transform 0.3s;
}

.bottom-bar.show {
  transform: translateY(0);
}

.send-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: var(--theme-gradient);
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.send-count {
  margin-left: 12rpx;
  font-size: 28rpx;
}

/* 自定义 TabBar 占位 */
