/* 入班申请审核页样式 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 班级横幅 */
.class-banner {
  padding: 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.banner-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

/* 申请列表 */
.request-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.request-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.request-item:last-child {
  border-bottom: none;
}

.request-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.request-info {
  flex: 1;
  min-width: 0;
}

.request-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.request-time {
  font-size: 24rpx;
  color: #999;
}

.request-actions {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

.action-btn {
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
}

.action-btn.reject {
  background: #fff1f0;
  color: #ff4d4f;
}

.action-btn.approve {
  background: #f6ffed;
  color: #52c41a;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-state .icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-state .text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #ccc;
  text-align: center;
  padding: 0 60rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 自定义 TabBar 占位 */
.container {
  /* padding-bottom 已通过 style 属性在 wxml 中处理 */
}
