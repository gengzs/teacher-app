/* 学生列表页样式 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 搜索栏 */
.search-bar {
  position: relative;
  margin-bottom: 20rpx;
}

.search-input {
  height: 80rpx;
  padding: 0 80rpx 0 30rpx;
  background: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.search-icon {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 10rpx 20rpx;
}

.filter-toggle {
  font-size: 28rpx;
  color: #666;
}

.filter-toggle .active {
  color: var(--theme-accent);
  font-weight: 500;
}

.filter-count {
  font-size: 26rpx;
  color: #999;
}

/* 学生列表 */
.student-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.student-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.student-item:last-child {
  border-bottom: none;
}

.student-item.left {
  opacity: 0.6;
}

.student-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 500;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.student-avatar.left {
  background: #ccc;
}

.student-info {
  flex: 1;
  min-width: 0;
}

.student-name {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.student-class {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.student-status {
  margin-right: 20rpx;
}

.status-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.status-tag.left {
  background: #f5f5f5;
  color: #999;
}

.status-tag.invite {
  background: var(--theme-light);
  color: var(--theme-accent);
}

.status-tag.manual {
  background: #f6ffed;
  color: #52c41a;
}

.student-action {
  flex-shrink: 0;
}

.action-btn {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.action-btn.remove {
  background: #fff1f0;
  color: #ff4d4f;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-state .icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-state .text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 20rpx 60rpx;
  background: var(--theme-accent);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}
