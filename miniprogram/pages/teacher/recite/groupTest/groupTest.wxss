/* 单词检测页 */
.test-page {
  min-height: 100vh;
  width: 100%;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(var(--theme-primary-rgb), 0.08) 0%, var(--theme-light) 100%);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 顶部 */
.test-header {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(74, 63, 68, 0.06);
  flex-shrink: 0;
  z-index: 10;
}
.header-left { width: 60rpx; flex-shrink: 0; }
.back-arrow { font-size: 52rpx; color: var(--theme-accent); font-weight: 300; }
.header-center { flex: 1; display: flex; flex-direction: column; align-items: center; }
.header-title { font-size: 32rpx; font-weight: 700; color: #4a3f44; }
.header-sub { font-size: 24rpx; color: #9b8a90; margin-top: 4rpx; }
.header-right { flex-shrink: 0; }
.marked-count { font-size: 26rpx; color: var(--theme-accent); font-weight: 600; }

/* 进度条 */
.test-progress {
  height: 8rpx;
  background: rgba(var(--theme-primary-rgb), 0.6);
  flex-shrink: 0;
}
.progress-fill {
  height: 100%;
  background: var(--theme-gradient);
  transition: width 0.4s ease;
}

/* 单词列表 */
.test-scroll {
  flex: 1;
  min-height: 0;
  height: 0;
  /* 右侧少留白，✓✗ 更贴屏幕右缘 */
  padding: 24rpx 8rpx 0 24rpx;
  box-sizing: border-box;
}
.test-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.test-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 12rpx 28rpx 24rpx;
  border: 1rpx solid rgba(var(--theme-primary-rgb), 0.65);
  box-shadow: 0 4rpx 16rpx rgba(74, 63, 68, 0.05);
  min-height: 100rpx;
  transition: background 0.2s ease, border-color 0.2s ease;
}
.test-row.row-right {
  background: #f0fff4;
  border-color: #95de64;
}
.test-row.row-wrong {
  background: #fff8f8;
  border-color: #ff9c9c;
}

.test-left {
  flex: 1;
  min-width: 0;
  margin-right: 12rpx;
}
.test-word {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #3d3538;
}
.test-hint {
  display: block;
  font-size: 24rpx;
  color: #52c41a;
  margin-top: 6rpx;
}
.test-hint.wrong-hint { color: #ff4d4f; }

/* 右侧按钮 */
.test-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  margin-right: 0;
}
.test-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  background: #f5f5f5;
  color: #ccc;
  border: 2rpx solid #e5e5e5;
  transition: all 0.2s;
}
.right-btn.active {
  background: linear-gradient(145deg, #f0fff4 0%, #d9f7be 100%);
  color: #237804;
  border-color: #95de64;
  box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.15);
}
.wrong-btn.active {
  background: linear-gradient(145deg, #fff5f5 0%, #ffccc7 100%);
  color: #a8071a;
  border-color: #ff9c9c;
  box-shadow: 0 4rpx 12rpx rgba(245, 34, 45, 0.12);
}

/* 底部大留白：最后一行点 ✓/✗ 时不易误触「查看检测结果」 */
.scroll-spacer { height: 420rpx; }

/* ========== 底部固定栏 ========== */
.test-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  padding: 24rpx 28rpx 16rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(248, 245, 247, 0) 0%, #f8f5f7 22%, #fff 50%);
  box-shadow: 0 -12rpx 40rpx rgba(74, 63, 68, 0.1);
}
.footer-stats {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 14rpx;
}
.stat-known { font-size: 24rpx; color: #52c41a; font-weight: 600; }
.stat-unknown { font-size: 24rpx; color: #ff4d4f; font-weight: 600; }

.finish-btn {
  width: 100%;
  padding: 28rpx;
  background: var(--theme-gradient);
  color: var(--theme-accent);
  border-radius: 44rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(196, 119, 134, 0.3);
}
.finish-btn.disabled {
  background: #ececec;
  color: #bbb;
  box-shadow: none;
}

/* ========== 检测结果弹窗 ========== */
.result-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 300;
}
.result-modal-mask.show { opacity: 1; visibility: visible; }

.result-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 680rpx;
  max-height: 85vh;
  background: #fff;
  border-radius: 28rpx;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 301;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.result-modal.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}

.result-modal-header {
  padding: 40rpx 40rpx 30rpx;
  text-align: center;
  background: linear-gradient(180deg, var(--theme-primary) 0%, #fff 100%);
}
.result-modal-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #5c4a50;
}

.result-modal-body {
  padding: 30rpx 40rpx;
  overflow-y: auto;
  flex: 1;
}

/* 正确率圆圈 */
.accuracy-circle {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
}
.accuracy-num {
  font-size: 96rpx;
  font-weight: 700;
  color: var(--theme-accent);
  line-height: 1;
}
.accuracy-label {
  font-size: 26rpx;
  color: #9b8a90;
  margin-top: 8rpx;
}

/* 结果卡片 */
.result-cards {
  display: flex;
  gap: 20rpx;
  margin-bottom: 36rpx;
}
.result-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx;
  border-radius: 16rpx;
}
.right-card { background: #f0fff4; }
.wrong-card { background: #fff8f8; }
.rc-value { font-size: 52rpx; font-weight: 700; color: #5c4a50; }
.rc-label { font-size: 24rpx; color: #9b8a90; margin-top: 8rpx; }

/* 操作按钮 */
.result-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.result-action-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx;
  background: #f8f5f7;
  border-radius: 16rpx;
}
.result-action-btn.print-btn {
  background: var(--theme-gradient);
}
.action-icon { font-size: 36rpx; }
.action-text { font-size: 30rpx; color: #4a3f44; font-weight: 500; }
.print-btn .action-text { color: var(--theme-accent); font-weight: 700; }

.result-modal-footer {
  padding: 20rpx 40rpx 40rpx;
}
.result-done-btn {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, var(--theme-accent) 0%, #a86070 100%);
  color: #fff;
  border-radius: 44rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
}
