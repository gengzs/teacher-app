/* 分组学习页 */
.learn-page {
  min-height: 100vh;
  width: 100%;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(var(--theme-primary-rgb), 0.14) 0%, #f8f5f7 100%);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ========== 顶部：极简，只显示组进度 ========== */
.learn-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  padding-top: calc(16rpx + env(safe-area-inset-top));
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(74, 63, 68, 0.06);
  flex-shrink: 0;
  z-index: 10;
}

.header-center {
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-sub { font-size: 28rpx; color: #4a3f44; font-weight: 600; letter-spacing: 1rpx; }

/* 进度条 */
.learn-progress {
  height: 8rpx;
  background: rgba(var(--theme-primary-rgb), 0.6);
  flex-shrink: 0;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--theme-primary) 0%, var(--theme-dark) 100%);
  transition: width 0.4s ease;
}

/* ========== 单词列表 ========== */
.learn-scroll {
  flex: 1;
  min-height: 0;
  height: 0;
  /* 右侧少留白，笔记列更贴屏幕右缘 */
  padding: 24rpx 8rpx 0 24rpx;
  box-sizing: border-box;
}

.word-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.word-row {
  display: flex;
  align-items: stretch;
  background: #fff;
  border-radius: 20rpx;
  border: 1rpx solid rgba(var(--theme-primary-rgb), 0.65);
  box-shadow: 0 4rpx 16rpx rgba(74, 63, 68, 0.05);
  min-height: 120rpx;
  overflow: hidden;
  transition: background 0.2s ease, border-color 0.2s ease;
  margin-right: 0;
}

.word-row.showed {
  background: linear-gradient(135deg, rgba(var(--theme-primary-rgb), 0.2) 0%, var(--theme-light) 100%);
  border-color: var(--theme-dark);
}

/* 单词主区：整行可点 */
.word-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 28rpx 12rpx 28rpx 28rpx;
  min-width: 0;
}

.word-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #3d3538;
  line-height: 1.3;
}

.word-meaning {
  display: flex;
  flex-direction: column;
  margin-top: 10rpx;
  gap: 4rpx;
}

.word-phonetic {
  font-size: 26rpx;
  color: #9b8a90;
}

.word-translation {
  font-size: 30rpx;
  color: var(--theme-accent);
  font-weight: 600;
}

.word-hint {
  font-size: 22rpx;
  color: #ccc;
  margin-top: 8rpx;
}

.word-hint.hint-step2 {
  color: var(--theme-accent);
  font-weight: 500;
}

.word-hint.hint-step3 {
  color: #b0a0a6;
}

/* 右侧笔记列：贴卡片右缘 */
.note-btn {
  width: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--theme-gradient);
  flex-shrink: 0;
  transition: background 0.2s;
  border-radius: 0 18rpx 18rpx 0;
  margin-right: 0;
}

.note-btn.has-note {
  background: linear-gradient(135deg, var(--theme-accent) 0%, #a86070 100%);
}

.note-icon { font-size: 36rpx; }

/* 底部留白 */
/* 底部导航较高，多留白避免误触「完成学习」 */
.scroll-bottom-spacer { height: 280rpx; }

/* 组间提示 */
.group-tip {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx 0 20rpx;
}
.tip-line {
  flex: 1;
  height: 1rpx;
  background: rgba(212, 160, 170, 0.3);
}
.tip-text { font-size: 24rpx; color: #b0a0a6; white-space: nowrap; }

/* ========== 底部导航 ========== */
.learn-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(74, 63, 68, 0.06);
  flex-shrink: 0;
  z-index: 10;
}

.nav-btn {
  padding: 24rpx 28rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.nav-btn.prev {
  background: #f5f5f5;
  color: #999;
}
.nav-btn.prev:not(.disabled) {
  background: var(--theme-primary);
  color: var(--theme-accent);
}

.nav-btn.next {
  background: var(--theme-gradient);
  color: var(--theme-accent);
  box-shadow: 0 4rpx 12rpx rgba(196, 119, 134, 0.2);
}

.nav-btn.next.finish {
  background: linear-gradient(135deg, var(--theme-accent) 0%, #a86070 100%);
  color: #fff;
}

.nav-dots {
  display: flex;
  gap: 8rpx;
  align-items: center;
}
.dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #e8dde1;
  transition: background 0.2s, width 0.2s;
}
.dot.active {
  background: var(--theme-accent);
  width: 24rpx;
  border-radius: 6rpx;
}

/* ========== 笔记弹窗 ========== */
.note-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 300;
}
.note-modal-mask.show { opacity: 1; visibility: visible; }

.note-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 640rpx;
  background: #fff;
  border-radius: 24rpx;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 301;
}
.note-modal.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}

.note-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}
.note-modal-title { font-size: 30rpx; font-weight: 600; color: #333; }
.note-modal-close { font-size: 40rpx; color: #999; padding: 10rpx; }

.note-modal-body { padding: 30rpx; }

.note-textarea {
  width: 100%;
  height: 240rpx;
  padding: 24rpx;
  background: #f8f5f7;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
  border: none;
  resize: none;
  line-height: 1.6;
}

.note-char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 12rpx;
}

.note-modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx 30rpx;
}

.note-btn-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #f5f5f5;
  color: #666;
  font-size: 30rpx;
  border-radius: 40rpx;
}

.note-btn-save {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: var(--theme-gradient);
  color: var(--theme-accent);
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
}
