.step-indicator { display: flex; align-items: center; justify-content: center; padding: 30rpx 0; margin-bottom: 24rpx; }
.step-item { display: flex; flex-direction: column; align-items: center; }
.step-dot { width: 48rpx; height: 48rpx; border-radius: 50%; background-color: #f0f0f0; color: #999999; font-size: 24rpx; font-weight: 600; display: flex; align-items: center; justify-content: center; margin-bottom: 8rpx; }
.step-item.active .step-dot { background: var(--theme-gradient); color: #ffffff; }
.step-text { font-size: 24rpx; color: #999999; }
.step-item.active .step-text { color: var(--theme-primary); }
.step-line { width: 80rpx; height: 4rpx; background-color: #f0f0f0; margin: 0 16rpx; margin-bottom: 28rpx; }
.step-line.active { background: var(--theme-gradient); }
.card-title { font-size: 32rpx; font-weight: 600; color: #333333; margin-bottom: 24rpx; }
.type-options { display: flex; flex-direction: column; }
.type-option { display: flex; align-items: center; padding: 30rpx; border: 2rpx solid #f0f0f0; border-radius: 16rpx; margin-bottom: 20rpx; transition: all 0.2s ease; }
.type-option.selected { border-color: var(--theme-primary); background-color: var(--theme-light); }
.type-icon { width: 80rpx; height: 80rpx; border-radius: 16rpx; background-color: #f5f5f5; display: flex; align-items: center; justify-content: center; font-size: 40rpx; margin-right: 20rpx; }
.type-option.selected .type-icon { background-color: #ffffff; }
.type-info { flex: 1; }
.type-name { font-size: 32rpx; font-weight: 600; color: #333333; display: block; margin-bottom: 8rpx; }
.type-desc { font-size: 26rpx; color: #999999; }
.type-check { width: 48rpx; height: 48rpx; border-radius: 50%; background: var(--theme-gradient); color: #ffffff; font-size: 28rpx; display: flex; align-items: center; justify-content: center; }
.form-item { margin-bottom: 20rpx; }
.form-label { font-size: 28rpx; font-weight: 500; color: #666666; display: block; margin-bottom: 12rpx; }
.class-grid { display: flex; flex-wrap: wrap; margin: 0 -8rpx 20rpx; }
.class-option { width: calc(50% - 16rpx); padding: 24rpx; border: 2rpx solid #f0f0f0; border-radius: 12rpx; margin: 8rpx; text-align: center; }
.class-option.selected { border-color: var(--theme-primary); background-color: var(--theme-light); }
.class-name { font-size: 28rpx; font-weight: 500; color: #333333; display: block; margin-bottom: 8rpx; }
.class-count { font-size: 24rpx; color: #999999; }
.form-input { width: 100%; padding: 24rpx; border: 2rpx solid #f0f0f0; border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box; }
.form-textarea { width: 100%; height: 200rpx; padding: 24rpx; border: 2rpx solid #f0f0f0; border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box; }
.date-picker { display: flex; justify-content: space-between; align-items: center; padding: 24rpx; border: 2rpx solid #f0f0f0; border-radius: 12rpx; }
.date-picker text:first-child { font-size: 28rpx; color: #333333; }
.arrow { font-size: 36rpx; color: #cccccc; }
.info-card { background-color: #f8f8f8; border-radius: 12rpx; padding: 24rpx; margin-top: 24rpx; }
.info-row { display: flex; justify-content: space-between; padding: 12rpx 0; }
.info-label { font-size: 26rpx; color: #999999; }
.info-value { font-size: 26rpx; color: #333333; }
.btn-primary { background: var(--theme-gradient); color: #ffffff; border-radius: 44rpx; padding: 28rpx 48rpx; font-size: 32rpx; text-align: center; }
.btn-secondary { background-color: #ffffff; color: var(--theme-primary); border: 2rpx solid var(--theme-primary); border-radius: 44rpx; padding: 28rpx 48rpx; font-size: 32rpx; text-align: center; }
.bottom-btns { display: flex; gap: 20rpx; margin-top: 40rpx; }
.bottom-btns .btn-primary, .bottom-btns .btn-secondary { flex: 1; }
