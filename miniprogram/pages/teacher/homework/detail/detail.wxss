.container {
  padding: 24rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.homework-header {
  display: flex;
  align-items: center;
}

.homework-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background-color: #E8F4FF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.homework-icon.word {
  background-color: var(--theme-light);
}

.homework-icon text {
  font-size: 40rpx;
}

.homework-info {
  flex: 1;
  min-width: 0;
}

.homework-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.homework-meta {
  font-size: 26rpx;
  color: #999999;
}

.homework-status {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  flex-shrink: 0;
}

.homework-status.ongoing {
  background-color: #E6F7FF;
  color: #1890FF;
}

.homework-status.completed {
  background-color: #F5F5F5;
  color: #999999;
}

.content-preview {
  padding: 24rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
}

.content-preview text {
  font-size: 28rpx;
  color: #666666;
  line-height: 2;
}

.progress-card {
  background: var(--theme-gradient);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-title {
  font-size: 28rpx;
  color: #ffffff;
}

.progress-count {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}

.progress-bar-wrapper {
  display: flex;
  align-items: center;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-fill {
  height: 100%;
  background-color: #ffffff;
  border-radius: 6rpx;
}

.progress-percent {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
  width: 70rpx;
  text-align: right;
}

.student-list {
  display: flex;
  flex-direction: column;
}

.student-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.student-item:last-child {
  border-bottom: none;
}

.student-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--theme-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.student-avatar.completed {
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
}

.student-avatar.pending {
  background: linear-gradient(135deg, #faad14 0%, #ffc53d 100%);
}

.student-avatar text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}

.student-info {
  flex: 1;
  min-width: 0;
}

.student-name {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  display: block;
  margin-bottom: 4rpx;
}

.submit-time {
  font-size: 24rpx;
  color: #999999;
}

.submit-time.pending {
  color: #faad14;
}

.student-score {
  display: flex;
  align-items: baseline;
  margin-right: 16rpx;
}

.score-num {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--theme-primary);
}

.score-label {
  font-size: 24rpx;
  color: #999999;
  margin-left: 4rpx;
}

.play-icon {
  font-size: 32rpx;
  color: var(--theme-primary);
}
