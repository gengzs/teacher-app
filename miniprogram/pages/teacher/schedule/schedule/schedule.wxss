.container { padding: 24rpx; }
.week-selector { display: flex; background-color: #ffffff; border-radius: 16rpx; padding: 8rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05); }
.week-day { flex: 1; text-align: center; padding: 16rpx 0; font-size: 28rpx; color: var(--theme-text); border-radius: 12rpx; }
.week-day.active { color: var(--theme-text); background: var(--theme-gradient); font-weight: 600; }
.card { background-color: #ffffff; border-radius: 20rpx; padding: 30rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06); }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.card-title { font-size: 32rpx; font-weight: 600; color: #333333; }
.add-btn { padding: 12rpx 24rpx; background: var(--theme-gradient); color: #ffffff; font-size: 26rpx; border-radius: 24rpx; }
.schedule-list { display: flex; flex-direction: column; }
.schedule-item { display: flex; align-items: center; padding: 20rpx 0; }
.schedule-time { width: 180rpx; font-size: 26rpx; color: #666666; }
.schedule-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background-color: var(--theme-primary); margin: 0 20rpx; }
.schedule-info { flex: 1; }
.schedule-class { font-size: 30rpx; font-weight: 500; color: #333333; display: block; margin-bottom: 4rpx; }
.schedule-subject { font-size: 26rpx; color: #999999; }
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 60rpx 0; }
.empty-state .icon { font-size: 100rpx; margin-bottom: 20rpx; opacity: 0.5; }
.empty-state .text { font-size: 28rpx; color: #999999; }
