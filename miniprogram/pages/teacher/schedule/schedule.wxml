<view class="container">
  <!-- 视图切换 -->
  <view class="view-toggle">
    <view class="toggle-btn {{viewMode === 'day' ? 'active' : ''}}" bindtap="toggleViewMode" wx:if="{{viewMode === 'week'}}">
      日视图
    </view>
    <view class="toggle-btn {{viewMode === 'week' ? 'active' : ''}}" bindtap="toggleViewMode" wx:if="{{viewMode === 'day'}}">
      周视图
    </view>
    <view class="add-btn" bindtap="addSchedule">+ 添加</view>
  </view>

  <!-- 日视图 -->
  <view wx:if="{{viewMode === 'day'}}">
    <!-- 星期选择 -->
    <scroll-view scroll-x class="week-scroll">
      <view class="week-selector">
        <view
          class="week-day {{currentWeekday === index ? 'active' : ''}}"
          wx:for="{{weekDays}}"
          wx:key="index"
          bindtap="selectDay"
          data-day="{{index}}"
        >
          <text class="day-label">{{item}}</text>
          <text class="day-date">{{formatDate(index)}}</text>
          <view class="day-dot" wx:if="{{weekSchedule[index] && weekSchedule[index].hasClass}}"></view>
        </view>
      </view>
    </scroll-view>

    <!-- 当日课程 -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">{{weekDays[currentWeekday]}}课程</text>
        <text class="card-count">{{currentDaySchedule.length}}节课</text>
      </view>

      <view class="schedule-list" wx:if="{{currentDaySchedule.length > 0}}">
        <view
          class="schedule-item"
          wx:for="{{currentDaySchedule}}"
          wx:key="index"
          bindtap="goToClass"
          data-classid="{{item.classId}}"
        >
          <view class="schedule-time-box">
            <text class="schedule-time">{{item.time}}</text>
          </view>
          <view class="schedule-dot"></view>
          <view class="schedule-info">
            <text class="schedule-class">{{item.className}}</text>
            <text class="schedule-subject">{{item.subject}}</text>
          </view>
          <text class="arrow">›</text>
        </view>
      </view>

      <view class="empty-state" wx:if="{{currentDaySchedule.length === 0}}">
        <text class="icon">📅</text>
        <text class="text">今日无课</text>
      </view>
    </view>
  </view>

  <!-- 周视图 -->
  <view wx:if="{{viewMode === 'week'}}">
    <view class="week-header">
      <text class="week-title">本周课程安排</text>
    </view>

    <view class="week-grid">
      <view
        class="week-day-card {{item.hasClass ? 'has-class' : ''}}"
        wx:for="{{weekSchedule}}"
        wx:key="day"
        bindtap="selectDay"
        data-day="{{item.day}}"
      >
        <view class="week-day-label">{{item.label}}</view>
        <view class="week-day-date">{{formatDate(item.day)}}</view>
        <view class="week-day-count" wx:if="{{item.hasClass}}">
          <text>{{item.count}}</text>
          <text class="count-label">节课</text>
        </view>
        <view class="week-day-empty" wx:if="{{!item.hasClass}}">
          <text>无课</text>
        </view>
      </view>
    </view>

    <!-- 选中天的详情 -->
    <view class="card" wx:if="{{currentDaySchedule.length > 0}}">
      <view class="card-header">
        <text class="card-title">{{weekDays[currentWeekday]}}详细课程</text>
      </view>
      <view class="schedule-list">
        <view
          class="schedule-item"
          wx:for="{{currentDaySchedule}}"
          wx:key="index"
        >
          <view class="schedule-time-box">
            <text class="schedule-time">{{item.time}}</text>
          </view>
          <view class="schedule-dot"></view>
          <view class="schedule-info">
            <text class="schedule-class">{{item.className}}</text>
            <text class="schedule-subject">{{item.subject}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
