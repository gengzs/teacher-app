/* 课表页面样式 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 视图切换 */
.view-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.toggle-btn {
  padding: 12rpx 32rpx;
  background: #fff;
  color: #666;
  font-size: 28rpx;
  border-radius: 28rpx;
}

.toggle-btn.active {
  background: var(--theme-accent);
  color: #fff;
}

.add-btn {
  padding: 12rpx 32rpx;
  background: #f6ffed;
  color: #52c41a;
  font-size: 28rpx;
  border-radius: 28rpx;
}

/* 星期选择 */
.week-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.week-selector {
  display: inline-flex;
  gap: 16rpx;
  padding: 10rpx 0;
}

.week-day {
  width: 120rpx;
  text-align: center;
  padding: 20rpx 16rpx;
  background: #fff;
  border-radius: 16rpx;
  position: relative;
}

.week-day.active {
  background: var(--theme-gradient);
  color: #fff;
}

.day-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.day-date {
  display: block;
  font-size: 24rpx;
  opacity: 0.7;
}

.day-dot {
  position: absolute;
  bottom: 12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  background: #52c41a;
  border-radius: 50%;
}

.week-day.active .day-dot {
  background: #fff;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.card-count {
  font-size: 26rpx;
  color: #999;
}

/* 课程列表 */
.schedule-list {
  margin-top: 10rpx;
}

.schedule-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.schedule-item:last-child {
  border-bottom: none;
}

.schedule-time-box {
  width: 140rpx;
  flex-shrink: 0;
}

.schedule-time {
  font-size: 26rpx;
  color: #666;
}

.schedule-dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--theme-accent);
  border-radius: 50%;
  margin: 0 20rpx;
  flex-shrink: 0;
}

.schedule-info {
  flex: 1;
}

.schedule-class {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.schedule-subject {
  font-size: 24rpx;
  color: #999;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-state .icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-state .text {
  font-size: 28rpx;
  color: #999;
}

/* 周视图 */
.week-header {
  padding: 10rpx 0 20rpx;
}

.week-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.week-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.week-day-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}

.week-day-card.has-class {
  border-left: 4rpx solid var(--theme-accent);
}

.week-day-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.week-day-date {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.week-day-count {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--theme-accent);
}

.week-day-count .count-label {
  font-size: 22rpx;
  font-weight: normal;
  color: #999;
  margin-left: 4rpx;
}

.week-day-empty {
  font-size: 26rpx;
  color: #ccc;
}
