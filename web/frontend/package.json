{
  "name": "teacher-web",
  "version": "1.0.0",
  "description": "Teacher App Web - 教师助手网页端",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "vue": "^3.3.8",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.5.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.teacher.app",
    "productName": "TeacherApp",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "../server/**/*.js",
      "../server/package.json",
      "../server/node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../server/.env.example",
        "to": "teacher-server.env.example"
      },
      {
        "from": "electron/api-origin.txt",
        "to": "api-origin.txt"
      },
      {
        "from": "electron/api-origin.example.txt",
        "to": "api-origin.example.txt"
      }
    ],
    "afterPack": "./electron/afterPack.cjs",
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "TeacherApp-Setup-${version}.exe"
    },
    "portable": {
      "artifactName": "TeacherApp-Portable-${version}.exe"
    },
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    }
  }
}
