<view class="container data-v-55a47082"><view class="class-banner data-v-55a47082"><text class="banner-title data-v-55a47082">{{className}}</text><text class="banner-subtitle data-v-55a47082">班级学习数据统计</text></view><view class="overview-grid data-v-55a47082"><view class="overview-card data-v-55a47082"><text class="overview-value data-v-55a47082">{{stats.totalStudents}}</text><text class="overview-label data-v-55a47082">班级人数</text></view><view class="overview-card data-v-55a47082"><text class="overview-value data-v-55a47082">{{stats.totalHomework}}</text><text class="overview-label data-v-55a47082">布置作业</text></view><view class="overview-card data-v-55a47082"><text class="overview-value data-v-55a47082">{{stats.completedHomework}}</text><text class="overview-label data-v-55a47082">完成人次</text></view><view class="overview-card highlight data-v-55a47082"><text class="overview-value data-v-55a47082">{{stats.avgScore}}</text><text class="overview-label data-v-55a47082">班级均分</text></view></view><view class="section data-v-55a47082"><view class="section-header data-v-55a47082"><text class="section-title data-v-55a47082">📈 本周学习趋势</text></view><view class="trend-card data-v-55a47082"><view class="trend-chart data-v-55a47082"><block wx:for="{{weeklyData}}" wx:for-item="item" wx:for-index="__i0__" wx:key="day"><view class="trend-bar data-v-55a47082" style="{{'height:'+(item.score/$root.m0*100+'%')+';'}}"><block wx:if="{{item.score>0}}"><view class="bar-fill data-v-55a47082"></view></block><block wx:if="{{item.score>0}}"><text class="bar-score data-v-55a47082">{{item.score}}</text></block></view></block></view><view class="trend-labels data-v-55a47082"><block wx:for="{{weeklyData}}" wx:for-item="item" wx:for-index="__i1__" wx:key="day"><text class="label-item data-v-55a47082">{{item.day}}</text></block></view></view></view><view class="section data-v-55a47082"><view class="section-header data-v-55a47082"><text class="section-title data-v-55a47082">🏆 学习标兵</text></view><view class="student-list data-v-55a47082"><block wx:for="{{topStudents}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['goToStudentDetail',['$0'],[[['topStudents','',index,'name']]]]]]]}}" class="student-item data-v-55a47082" bindtap="__e"><view class="{{['rank','data-v-55a47082',(index<3)?'top':'']}}">{{index+1}}</view><view class="student-info data-v-55a47082"><text class="student-name data-v-55a47082">{{item.name}}</text><text class="student-meta data-v-55a47082">{{"完成 "+item.completed+" 次"}}</text></view><view class="student-score data-v-55a47082">{{item.avgScore+"分"}}</view></view></block></view></view><block wx:if="{{$root.g0>0}}"><view class="section data-v-55a47082"><view class="section-header data-v-55a47082"><text class="section-title data-v-55a47082">⚠️ 需要关注</text></view><view class="student-list warning data-v-55a47082"><block wx:for="{{weakStudents}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view data-event-opts="{{[['tap',[['goToStudentDetail',['$0'],[[['weakStudents','',index,'name']]]]]]]}}" class="student-item data-v-55a47082" bindtap="__e"><view class="rank warning-rank data-v-55a47082">!</view><view class="student-info data-v-55a47082"><text class="student-name data-v-55a47082">{{item.name}}</text><text class="student-meta data-v-55a47082">{{"完成 "+item.completed+" 次 · 需跟进"}}</text></view><view class="student-score warning data-v-55a47082">{{item.avgScore+"分"}}</view></view></block></view></view></block><view class="section data-v-55a47082"><view class="section-header data-v-55a47082"><text class="section-title data-v-55a47082">📝 最近作业完成情况</text></view><view class="homework-list data-v-55a47082"><block wx:for="{{recentHomework}}" wx:for-item="item" wx:for-index="__i2__" wx:key="title"><view class="homework-item data-v-55a47082"><view class="homework-info data-v-55a47082"><text class="homework-title data-v-55a47082">{{item.title}}</text><view class="homework-progress-bar data-v-55a47082"><view class="progress-fill data-v-55a47082" style="{{'width:'+(item.submitRate+'%')+';'}}"></view></view></view><view class="homework-stats data-v-55a47082"><text class="submit-rate data-v-55a47082">{{item.submitRate+"%"}}</text><text class="avg-score data-v-55a47082">{{"均分 "+item.avgScore}}</text></view></view></block></view></view></view>