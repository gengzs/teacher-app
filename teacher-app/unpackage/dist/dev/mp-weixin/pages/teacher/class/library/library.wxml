<view class="container data-v-2b9b7f3a"><view class="search-bar data-v-2b9b7f3a"><input class="search-input data-v-2b9b7f3a" placeholder="搜索文章" data-event-opts="{{[['input',[['__set_model',['','searchKey','$event',[]]]]]]}}" value="{{searchKey}}" bindinput="__e"/><view class="search-icon data-v-2b9b7f3a">🔍</view></view><scroll-view class="category-scroll data-v-2b9b7f3a" scroll-x="{{true}}"><view class="category-list data-v-2b9b7f3a"><block wx:for="{{categories}}" wx:for-item="item" wx:for-index="__i0__" wx:key="key"><view data-event-opts="{{[['tap',[['selectCategory',['$0'],[[['categories','key',item.key,'key']]]]]]]}}" class="{{['category-item','data-v-2b9b7f3a',(currentCategory===item.key)?'active':'']}}" bindtap="__e">{{item.label}}</view></block></view></scroll-view><view class="action-bar data-v-2b9b7f3a"><view data-event-opts="{{[['tap',[['selectAll',['$event']]]]]}}" class="action-btn data-v-2b9b7f3a" bindtap="__e">全选</view><view data-event-opts="{{[['tap',[['clearSelection',['$event']]]]]}}" class="action-btn data-v-2b9b7f3a" bindtap="__e">清空</view><text class="selection-count data-v-2b9b7f3a">{{"已选 "+$root.g0+" 篇"}}</text></view><view class="article-list data-v-2b9b7f3a"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="__i1__" wx:key="_id"><view data-event-opts="{{[['tap',[['e0',['$event']]]]]}}" data-event-params="{{({item:item.$orig})}}" class="{{['article-item','data-v-2b9b7f3a',(item.m0)?'selected':'']}}" bindtap="__e"><view class="article-checkbox data-v-2b9b7f3a"><view class="{{['checkbox','data-v-2b9b7f3a',(item.m1)?'checked':'']}}"><block wx:if="{{item.m2}}"><text class="data-v-2b9b7f3a">✓</text></block></view></view><view data-event-opts="{{[['tap',[['e1',['$event']]]]]}}" data-event-params="{{({item:item.$orig})}}" class="article-content data-v-2b9b7f3a" catchtap="__e"><view class="article-header data-v-2b9b7f3a"><text class="article-title data-v-2b9b7f3a">{{item.$orig.title}}</text><view class="article-meta data-v-2b9b7f3a"><text cl