w><view class="module-content data-v-245f7662"><text class="module-title data-v-245f7662">班级资料库</text><text class="module-desc data-v-245f7662">文章列表，可选几篇发送</text></view><text class="module-arrow data-v-245f7662">›</text></view></view><view class="section data-v-245f7662"><view class="section-header data-v-245f7662"><text class="section-title data-v-245f7662">📖 上课</text></view><view class="action-row data-v-245f7662"><view data-event-opts="{{[['tap',[['startClass',['$event']]]]]}}" class="action-card primary data-v-245f7662" bindtap="__e"><view class="action-icon data-v-245f7662">🎯</view><text class="action-title data-v-245f7662">单词带背</text><text class="action-desc data-v-245f7662">抗遗忘复习</text></view><view data-event-opts="{{[['tap',[['goToClassHistory',['$event']]]]]}}" class="action-card data-v-245f7662" bindtap="__e"><view class="action-icon data-v-245f7662">📜</view><text class="action-title data-v-245f7662">历史课程</text><text class="action-desc data-v-245f7662">查看上课记录</text></view></view></view><view class="section data-v-245f7662"><view class="section-header data-v-245f7662"><text class="section-title data-v-245f7662">📝 布置作业</text></view><view class="action-row data-v-245f7662"><view data-event-opts="{{[['tap',[['assignHomework',['$event']]]]]}}" class="action-card primary data-v-245f7662" bindtap="__e"><view class="action-icon data-v-245f7662">📝</view><text class="action-title data-v-245f7662">选资料库文章</text><text class="action-desc data-v-245f7662">语音打卡</text></view><view data-event-opts="{{[['tap',[['assignHomework',['$event']]]]]}}" class="action-card data-v-245f7662" bindtap="__e"><view class="action-icon data-v-245f7662">🎤</view><text class="action-title data-v-245f7662">其他作业</text><text class="action-desc data-v-245f7662">自由布置</text></view></view><block wx:if="{{$root.g2>0}}"><view class="homework-list data-v-245f7662"><block wx:for="{{recentHomework}}" wx:for-item="item" wx:for-index="__i0__" wx:key="_id"><view data-event-opts="{{[['tap',[['goToHomeworkDetail',['$0'],[[['recentHomework','_id',item._id,'_id']]]]]]]}}" class="homework-item data-v-245f7662" bindtap="__e"><view class="homework-icon data-v-245f7662">📄</view><view class="homework-info data-v-245f7662"><text class="homework-title data-v-245f7662">{{item.title}}</text><text class="homework-meta data-v-245f7662">{{"截止 "+item.deadline}}</text></view><view class="homework-progress data-v-245f7662"><text class="progress-text data-v-245f7662">{{item.submitCount+"/"+item.totalCount}}</text><text class="progress-label data-v-245f7662">已交</text></view></view></block></view></block></view><view class="section data-v-245f7662"><view class="section-header data-v-245f7662"><text class="section-title data-v-245f7662">📊 班级统计</text><text data-event-opts="{{[['tap',[['goToStats',['$event']]]]]}}" class="section-more data-v-245f7662" bindtap="__e">详情 ›</text></view><view class="stats-row data-v-245f7662"><view class="stat-item data-v-245f7662"><text class="stat-value data-v-245f7662">{{stats.totalStudents}}</text><text class="stat-label data-v-245f7662">总人数</text></view><view class="stat-item data-v-245f7662"><text class="stat-value data-v-245f7662">{{stats.homeworkDone}}</text><text class="stat-label data-v-245f7662">作业完成</text></view><view class="stat-item data-v-245f7662"><text class="stat-value data-v-245f7662">{{stats.avgScore}}</text><text class="stat-label data-v-245f7662">平均分</text></view></view></view><view class="{{['modal','data-v-245f7662',(showAddModal)?'show':'']}}"><view class="modal-header data-v-245f7662"><text class="modal-title data-v-245f7662">添加学生</text><view data-event-opts="{{[['tap',[['hideAddModal',['$event']]]]]}}" class="modal-close data-v-245f7662" bindtap="__e">✕</view></view><block wx:if="{{!newStudentResult}}"><view class="modal-body data-v-245f7662"><view class="form-item data-v-245f7662"><text class="form-label data-v-245f7662">学生姓名 *</text><input class="form-input data-v-245f7662" placeholder="请输入学生姓名" data-event-opts="{{[['input',[['__set_model',['','addName','$event',[]]]]]]}}" value="{{addName}}" bindinput="__e"/></view><view class="form-item data-v-245f7662"><text class="form-label data-v-245f7662">手机号（可选）</text><input class="form-input data-v-245f7662" type="number" placeholder="用于账号绑定" data-event-opts="{{[['input',[['__set_model',['','addPhone','$event',[]]]]]]}}" value="{{addPhone}}" bindinput="__e"/></view><view class="form-hint data-v-245f7662"><text class="hint-icon data-v-245f7662">💡</text><text class="hint-text data-v-245f7662">添加后系统会生成临时账号密码，请妥善保存</text></view><view class="modal-footer data-v-245f7662"><view data-event-opts="{{[['tap',[['hideAddModal',['$event']]]]]}}" class="btn-cancel data-v-245f7662" bindtap="__e">取消</view><view data-event-opts="{{[['tap',[['submitAddStudent',['$event']]]]]}}" class="{{['btn-confirm','data-v-245f7662',(addLoading)?'loading':'']}}" bindtap="__e">{{''+(addLoading?'添加中...':'确认添加')+''}}</view></view></view></block><block wx:if="{{newStudentResult}}"><view class="modal-body result-body data-v-245f7662"><view class="result-icon data-v-245f7662">✅</view><view class="result-title data-v-245f7662">添加成功</view><view class="result-info data-v-245f7662"><view class="info-row data-v-245f7662"><text class="info-label data-v-245f7662">姓名</text><text class="info-value data-v-245f7662">{{newStudentResult.name}}</text></view><block wx:if="{{newStudentResult.phone}}"><view class="info-row data-v-245f7662"><text class="info-label data-v-245f7662">手机</text><text class="info-value data-v-245f7662">{{newStudentResult.phone}}</text></view></block><view class="info-row data-v-245f7662"><text class="info-label data-v-245f7662">初始密码</text><text class="info-value highlight data-v-245f7662">{{newStudentResult.tempPassword}}</text></view></view><view class="result-tip data-v-245f7662"><text class="tip-icon data-v-245f7662">⚠️</text><text class="tip-text data-v-245f7662">请将此账号信息发给家长或学生</text></view><view class="modal-footer data-v-245f7662"><view data-event-opts="{{[['tap',[['copyAccountInfo',['$event']]]]]}}" class="btn-secondary data-v-245f7662" bindtap="__e">复制账号信息</view><view data-event-opts="{{[['tap',[['continueAdd',['$event']]]]]}}" class="btn-confirm data-v-245f7662" bindtap="__e">继续添加</view></view></view></block></view><block wx:if="{{showAddModal}}"><view data-event-opts="{{[['tap',[['hideAddModal',['$event']]]]]}}" class="modal-overlay data-v-245f7662" bindtap="__e"></view></block></view>