
.container.data-v-0fa74af9 {
  padding: 24rpx;
  padding-bottom: 140rpx;
}
.view-toggle.data-v-0fa74af9 {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-bottom: 20rpx;
}
.toggle-btn.data-v-0fa74af9 {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #999;
  background: #fff;
  border-radius: 20rpx;
