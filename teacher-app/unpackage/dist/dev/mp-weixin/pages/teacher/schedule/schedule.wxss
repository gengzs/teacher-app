  background: #fff;
  border-radius: 16rpx;
}
.week-day.data-v-0fa74af9 {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  min-width: 100rpx;
}
.week-day.active.data-v-0fa74af9 {
  background: var(--theme-light);
}
.day-label.data-v-0fa74af9 {
  font-size: 26rpx;
  color: #666;
