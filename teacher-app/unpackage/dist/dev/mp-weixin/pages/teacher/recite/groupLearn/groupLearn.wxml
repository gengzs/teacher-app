<view class="learn-page data-v-46092b90"><view class="learn-header data-v-46092b90"><view class="header-center data-v-46092b90"><text class="header-sub data-v-46092b90">{{"第 "+(currentGroupIndex+1)+" / "+totalGroups+" 组 · 共 "+totalCount+" 词"}}</text></view></view><view class="learn-progress data-v-46092b90"><view class="progress-fill data-v-46092b90" style="{{'width:'+(progressPercent+'%')+';'}}"></view></view><scroll-view class="learn-scroll data-v-46092b90" scroll-y="{{true}}"><view class="word-list data-v-46092b90"><block wx:for="{{currentGroup}}" wx:for-item="item" wx:for-index="index" wx:key="_id"><view class="{{['word-row','data-v-46092b90',(item.showMeaning)?'showed':'']}}"><view data-event-opts="{{[['tap',[['onWordTap',[index]]]]]}}" class="word-main data-v-46092b90" bindtap="__e"><text class="word-text data-v-46092b90">{{item.word}}</text><block wx:if="{{item.showMeaning}}"><view class="word-meaning data-v-46092b90"><text class="word-phonetic data-v-46092b90">{{item.phonetic}}</text><text class="word-translation data-v-46092b90">{{item.translation}}</text></view></block><block wx:if="{{!item.showMeaning&&!item.heardOnce}}"><text class="word-hint data-v-46092b90">点1次：听发音</text></block><block wx:if="{{!item.showMeaning&&item.heardOnce}}"><text class="word-hint hint-step2 data-v-46092b90">点2次：显示释义</text></block><block wx:if="{{item.showMeaning}}"><text class="word-hint hint-step3 data-v-46092b90">点3次：收起</text></block></view><view data-event-opts="{{[['tap',[['openNoteInput',[index]]]]]}}" class="{{['note-btn','data-v-46092b90',(item.note)?'has-note':'']}}" bindtap="__e"><text class="note-icon data-v-46092b90">{{item.note?'📝':'✏️'}}</text></view></view></block></view><block wx:if="{{totalGroups>1}}"><view class="group-tip data-v-46092b90"><text class="tip-line data-v-46092b90"></text><text class="tip-text data-v-46092b90">学完本组后点「下一组」继续</text><text class="tip-line data-v-46092b90"></text></view></block><view class="scroll-bottom-spacer data-v-46092b90"></view></scroll-view><view class="learn-footer data-v-46092b90"><view data-event-opts="{{[['tap',[['prevGroup',['$event']]]]]}}" class="{{['nav-btn','prev','data-v-46092b90',(currentGroupIndex===0)?'disabled':'']}}" bindtap="__e">‹ 上一组</view><view class="nav-dots data-v-46092b90"><block wx:for="{{totalGroups}}" wx:for-item="item" wx:for-index="idx" wx:key="idx"><view class="{{['dot','data-v-46092b90',(idx===currentGroupIndex)?'active':'']}}"></view></block></view><view data-event-opts="{{[['tap',[['nextGroup',['$event']]]]]}}" class="{{['nav-btn','next','data-v-46092b90',(currentGroupIndex===totalGroups-1)?'finish':'']}}" bindtap="__e">{{currentGroupIndex===totalGroups-1?'完成学习 ›':'下一组 ›'}}</view></view><view data-event-opts="{{[['tap',[['closeNoteModal',['$event']]]]]}}" class="{{['note-modal-mask','data-v-46092b90',(showNoteModal)?'show':'']}}" bindtap="__e"></view><view class="{{['note-modal','data-v-46092b90',(showNoteModal)?'show':'']}}"><view class="note-modal-header data-v-46092b90"><text class="note-modal-title data-v-46092b90">{{"📝 为「"+noteTargetWord+"」添加笔记"}}</text><view data-event-opts="{{[['tap',[['closeNoteModal',['$event']]]]]}}" class="note-modal-close data-v-46092b90" bindtap="__e">✕</view></view><view class="note-modal-body data-v-46092b90"><textarea class="note-textarea data-v-46092b90" placeholder="记录这个单词的记忆技巧、例句、联想等..." maxlength="200" auto-focus="{{true}}" data-event-opts="{{[['input',[['__set_model',['','noteContent','$event',[]]]]]]}}" value="{{noteContent}}" bindinput="__e"></textarea><text class="note-char-count data-v-46092b90">{{$root.g0+" / 200"}}</text></view><view class="note-modal-footer data-v-46092b90"><view data-event-opts="{{[['tap',[['closeNoteModal',['$event']]]]]}}" class="note-btn-cancel data-v-46092b90" bindtap="__e">取消</view><view data-event-opts="{{[['tap',[['saveNote',['$event']]]]]}}" class="note-btn-save data-v-46092b90" bindtap="__e">保存笔记</view></view></view></view>