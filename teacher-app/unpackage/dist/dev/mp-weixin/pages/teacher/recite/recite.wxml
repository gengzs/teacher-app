<view class="recite-page data-v-56788ace"><block wx:if="{{mode==='filtering'}}"><view class="filtering-mode data-v-56788ace"><view class="filter-header data-v-56788ace"><view class="header-info data-v-56788ace"><text class="set-name data-v-56788ace">{{setName||'单词带背'}}</text><text class="progress-text data-v-56788ace">{{"已标记 "+(knownCount+unknownCount)+" / 共 "+totalCount+" 词"}}</text></view><view class="header-actions data-v-56788ace"><view data-event-opts="{{[['tap',[['goChooseWordSet',['$event']]]]]}}" class="text-btn data-v-56788ace" bindtap="__e">换词库</view><view data-event-opts="{{[['tap',[['exit',['$event']]]]]}}" class="text-btn data-v-56788ace" bindtap="__e">退出</view></view></view><view class="progress-bar data-v-56788ace"><view class="progress-known data-v-56788ace" style="{{'width:'+(totalCount>0?knownCount/totalCount*100+'%':'0%')+';'}}"></view><view class="progress-unknown data-v-56788ace" style="{{'width:'+(totalCount>0?unknownCount/totalCount*100+'%':'0%')+';'}}"></view></view><view class="progress-labels data-v-56788ace"><text class="label known data-v-56788ace">{{"✓ 认识 "+knownCount}}</text><text class="label unknown data-v-56788ace">{{"✗ 待学习 "+unknownCount}}</text></view><scroll-view class="filter-scroll data-v-56788ace" scroll-y="{{true}}"><block wx:for="{{allWords}}" wx:for-item="item" wx:for-index="index" wx:key="_id"><view class="{{['filter-row','data-v-56788ace',(item.filterStatus==='known')?'row-known':'',(item.filterStatus==='unknown')?'row-unknown':'']}}"><view class="filter-row-main data-v-56788ace"><text class="filter-word data-v-56788ace">{{item.word}}</text><block wx:if="{{item.phonetic}}"><text class="filter-sub data-v-56788ace">{{item.phonetic}}</text></block></view><view class="filter-row-actions data-v-56788ace"><view data-event-opts="{{[['tap',[['markKnownAt',[index]]]]]}}" class="{{['row-btn','known-btn','data-v-56788ace',(item.filterStatus==='known')?'active':'']}}" bindtap="__e">✓</view><view data-event-opts="{{[['tap',[['markUnknownAt',[index]]]]]}}" class="{{['row-btn','unknown-btn','data-v-56788ace',(item.filterStatus==='unknown')?'active':'']}}" bindtap="__e">✗</view></view></view></block><view class="filter-scroll-spacer data-v-56788ace"></view></scroll-view><view class="start-learning-bar data-v-56788ace"><block wx:if="{{unknownCount===0}}"><view class="start-learning-hint data-v-56788ace">请先点右侧 ✗ 标记不认识的词</view></block><view data-event-opts="{{[['tap',[['onStartLearningTap',['$event']]]]]}}" class="{{['start-learning-btn','data-v-56788ace',(unknownCount<=0)?'disabled':'']}}" bindtap="__e">{{''+(unknownCount>0?'进入分组学习（'+unknownCount+' 个待学）›':'进入分组学习')+''}}</view></view></view></block><block wx:if="{{mode==='result'}}"><view class="result-mode data-v-56788ace"><view class="result-icon data-v-56788ace">🎉</view><text class="result-title data-v-56788ace">筛选完成！</text><text class="result-subtitle data-v-56788ace">{{setName}}</text><view class="result-stats data-v-56788ace"><view class="stat-card known-card data-v-56788ace"><text class="stat-value data-v-56788ace">{{knownCount}}</text><text class="stat-label data-v-56788ace">认识</text></view><view class="stat-card unknown-card data-v-56788ace"><text class="stat-value data-v-56788ace">{{unknownCount}}</text><text class="stat-label data-v-56788ace">不认识</text></view><view class="stat-card total-card data-v-56788ace"><text class="stat-value data-v-56788ace">{{totalCount}}</text><text class="stat-label data-v-56788ace">总单词</text></view></view><block wx:if="{{totalCount>0}}"><view class="accuracy-display data-v-56788ace"><text class="accuracy-value data-v-56788ace">{{accuracyPercent+"%"}}</text><text class="accuracy-label data-v-56788ace">认识占比</text></view></block><view class="result-actions data-v-56788ace"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="result-btn outline data-v-56788ace" bindtap="__e">词库管理</view><view data-event-opts="{{[['tap',[['restart',['$event']]]]]}}" class="result-btn primary data-v-56788ace" bindtap="__e">再来一次</view></view></view></block></view>