<view class="test-page data-v-1c4ade54"><view class="test-header data-v-1c4ade54"><view data-event-opts="{{[['tap',[['goBack',['$event']]]]]}}" class="header-left data-v-1c4ade54" bindtap="__e"><text class="back-arrow data-v-1c4ade54">‹</text></view><view class="header-center data-v-1c4ade54"><text class="header-title data-v-1c4ade54">{{setName||'单词检测'}}</text><text class="header-sub data-v-1c4ade54">{{"全部 "+totalCount+" 个词"}}</text></view><view class="header-right data-v-1c4ade54"><text class="marked-count data-v-1c4ade54">{{markedCount+" / "+totalCount}}</text></view></view><view class="test-progress data-v-1c4ade54"><view class="progress-fill data-v-1c4ade54" style="{{'width:'+(progressPercent+'%')+';'}}"></view></view><scroll-view class="test-scroll data-v-1c4ade54" scroll-y="{{true}}"><view class="test-list data-v-1c4ade54"><block wx:for="{{allWords}}" wx:for-item="item" wx:for-index="index" wx:key="_id"><view class="{{['test-row','data-v-1c4ade54',(item.testStatus==='right')?'row-right':'',(item.testStatus==='wrong')?'row-wrong':'']}}"><view class="test-left data-v-1c4ade54"><text class="test-word data-v-1c4ade54">{{item.word}}</text><block wx:if="{{item.testStatus==='right'}}"><text class="test-hint data-v-1c4ade54">✓ 认识</text></block><block wx:if="{{item.testStatus==='wrong'}}"><text class="test-hint wrong-hint data-v-1c4ade54">✗ 不认识</text></block></view><view class="test-actions data-v-1c4ade54"><view data-event-opts="{{[['tap',[['onMarkRight',[index]]]]]}}" class="{{['test-btn','right-btn','data-v-1c4ade54',(item.testStatus==='right')?'active':'']}}" catchtap="__e">✓</view><view data-event-opts="{{[['tap',[['onMarkWrong',[index]]]]]}}" class="{{['test-btn','wrong-btn','data-v-1c4ade54',(item.testStatus==='wrong')?'active':'']}}" catchtap="__e">✗</view></view></view></block></view><view class="scroll-spacer data-v-1c4ade54"></view></scroll-view><view class="test-footer data-v-1c4ade54"><view class="footer-stats data-v-1c4ade54"><text class="stat-known data-v-1c4ade54">{{"✓ 认识 "+rightCount}}</text><text class="stat-unknown data-v-1c4ade54">{{"✗ 不认识 "+wrongCount}}</text></view><view data-event-opts="{{[['tap',[['onFinishTest',['$event']]]]]}}" class="{{['finish-btn','data-v-1c4ade54',(markedCount===0)?'disabled':'']}}" bindtap="__e">{{markedCount>0?'查看检测结果':'请先标记'}}</view></view><view data-event-opts="{{[['tap',[['closeResult',['$event']]]]]}}" class="{{['result-modal-mask','data-v-1c4ade54',(showResult)?'show':'']}}" bindtap="__e"></view><view class="{{['result-modal','data-v-1c4ade54',(showResult)?'show':'']}}"><view class="result-modal-header data-v-1c4ade54"><text class="result-modal-title data-v-1c4ade54">🎉 检测完成</text></view><view class="result-modal-body data-v-1c4ade54"><view class="accuracy-circle data-v-1c4ade54"><text class="accuracy-num data-v-1c4ade54">{{accuracyPercent+"%"}}</text><text class="accuracy-label data-v-1c4ade54">正确率</text></view><view class="result-cards data-v-1c4ade54"><view class="result-card right-card data-v-1c4ade54"><text class="rc-value data-v-1c4ade54">{{rightCount}}</text><text class="rc-label data-v-1c4ade54">✓ 认识</text></view><view class="result-card wrong-card data-v-1c4ade54"><text class="rc-value data-v-1c4ade54">{{wrongCount}}</text><text class="rc-label data-v-1c4ade54">✗ 不认识</text></view></view><view class="result-actions data-v-1c4ade54"><view data-event-opts="{{[['tap',[['onPrintNotes',['$event']]]]]}}" class="result-action-btn print-btn data-v-1c4ade54" bindtap="__e"><text class="action-icon data-v-1c4ade54">🖨️</text><text class="action-text data-v-1c4ade54">打印笔记 PDF</text></view><view data-event-opts="{{[['tap',[['onRetryTest',['$event']]]]]}}" class="result-action-btn data-v-1c4ade54" bindtap="__e"><text class="action-icon data-v-1c4ade54">🔄</text><text class="action-text data-v-1c4ade54">重新检测</text></view><view data-event-opts="{{[['tap',[['onBackToLearn',['$event']]]]]}}" class="result-action-btn data-v-1c4ade54" bindtap="__e"><text class="action-icon data-v-1c4ade54">📖</text><text class="action-text data-v-1c4ade54">返回学习</text></view></view></view><view class="result-modal-footer data-v-1c4ade54"><view data-event-opts="{{[['tap',[['onFinishAndBack',['$event']]]]]}}" class="result-done-btn data-v-1c4ade54" bindtap="__e">完成，返回课程</view></view></view></view>