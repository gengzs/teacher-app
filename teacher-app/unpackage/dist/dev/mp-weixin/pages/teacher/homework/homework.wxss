
.container.data-v-6cee3f19 {
  padding: 24rpx;
  padding-bottom: 140rpx;
}
.filter-bar.data-v-6cee3f19 {
  display: flex;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.filter-item.data-v-6cee3f19 {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666666;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}
.filter-item.active.data-v-6cee3f19 {
  color: #ffffff;
  background: var(--theme-gradient);
  font-weight: 600;
}
.homework-list.data-v-6cee3f19 {
  display: flex;
  flex-direction: column;
}
.homework-item.data-v-6cee3f19 {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.homework-item.data-v-6cee3f19:last-child {
  border-bottom: none;
}
.homework-main.data-v-6cee3f19 {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.homework-icon.data-v-6cee3f19 {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.homework-icon.voice.data-v-6cee3f19 {
  background-color: #E8F4FF;
}
.homework-icon.word.data-v-6cee3f19 {
  background-color: var(--theme-light);
}
.homework-icon text.data-v-6cee3f19 {
  font-size: 36rpx;
}
.homework-info.data-v-6cee3f19 {
  flex: 1;
  min-width: 0;
}
.homework-title.data-v-6cee3f19 {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  display: block;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.homework-meta.data-v-6cee3f19 {
  font-size: 26rpx;
  color: #999999;
}
.homework-status.data-v-6cee3f19 {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  flex-shrink: 0;
}
.homework-status.ongoing.data-v-6cee3f19 {
  background-color: #E6F7FF;
  color: #1890FF;
}
.homework-status.completed.data-v-6cee3f19 {
  background-color: #F5F5F5;
  color: #999999;
}
.homework-progress.data-v-6cee3f19 {
  display: flex;
  align-items: center;
  padding-left: 88rpx;
}
.progress-bar.data-v-6cee3f19 {
  flex: 1;
  height: 8rpx;
  background-color: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
  margin-right: 16rpx;
}
.progress-fill.data-v-6cee3f19 {
  height: 100%;
  background: linear-gradient(90deg, var(--theme-primary) 0%, var(--theme-dark) 100%);
  border-radius: 4rpx;
}
.progress-text.data-v-6cee3f19 {
  font-size: 24rpx;
  color: var(--theme-primary);
  font-weight: 500;
  width: 80rpx;
  text-align: right;
}
.bottom-action.data-v-6cee3f19 {
  position: fixed;
  /* 自定义 Tab 栏高度约 100rpx + 安全区 */
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: 20rpx;
  background-color: var(--theme-light);
}
.btn-primary.data-v-6cee3f19 {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--theme-gradient);
  color: #ffffff;
  border-radius: 44rpx;
  padding: 28rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
}
.btn-primary.data-v-6cee3f19:active {
  opacity: 0.85;
}
.btn-icon.data-v-6cee3f19 {
  font-size: 40rpx;
  margin-right: 8rpx;
}
.empty-state.data-v-6cee3f19 {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}
.empty-state .icon.data-v-6cee3f19 {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}
.empty-state .text.data-v-6cee3f19 {
  font-size: 28rpx;
  color: #999999;
}

