<view class="container data-v-b49079d4"><view class="step-indicator data-v-b49079d4"><view class="{{['step-item','data-v-b49079d4',(currentStep>=1)?'active':'']}}"><view class="step-dot data-v-b49079d4">{{currentStep>1?'✓':'1'}}</view><text class="step-label data-v-b49079d4">类型</text></view><view class="{{['step-line','data-v-b49079d4',(currentStep>=2)?'active':'']}}"></view><view class="{{['step-item','data-v-b49079d4',(currentStep>=2)?'active':'']}}"><view class="step-dot data-v-b49079d4">{{currentStep>2?'✓':'2'}}</view><text class="step-label data-v-b49079d4">内容</text></view><view class="{{['step-line','data-v-b49079d4',(currentStep>=3)?'active':'']}}"></view><view class="{{['step-item','data-v-b49079d4',(currentStep>=3)?'active':'']}}"><view class="step-dot data-v-b49079d4">3</view><text class="step-label data-v-b49079d4">时间</text></view></view><block wx:if="{{currentStep===1}}"><view class="step-content data-v-b49079d4"><view class="card data-v-b49079d4"><view class="card-title data-v-b49079d4">选择作业类型</view><view class="type-options data-v-b49079d4"><block wx:for="{{typeOptions}}" wx:for-item="item" wx:for-index="__i0__" wx:key="key"><view data-event-opts="{{[['tap',[['selectType',['$0'],[[['typeOptions','key',item.key,'key']]]]]]]}}" class="{{['type-option','data-v-b49079d4',(homeworkType===item.key)?'selected':'']}}" bindtap="__e"><view class="type-icon data-v-b49079d4">{{item.icon}}</view><view class="type-info data-v-b49079d4"><text class="type-label data-v-b49079d4">{{item.label}}</text><text class="type-desc data-v-b49079d4">{{item.desc}}</text></view><block wx:if="{{homeworkType===item.key}}"><view class="type-check data-v-b49079d4">✓</view></block></view></block></view></view><view class="bottom-btn data-v-b49079d4"><view data-event-opts="{{[['tap',[['nextStep',['$event']]]]]}}" class="btn-primary data-v-b49079d4" bindtap="__e">下一步</view></view></view></block><block wx:if="{{currentStep===2}}"><view class="step-content data-v-b49079d4"><view class="card data-v-b49079d4"><view class="card-title data-v-b49079d4">选择班级</view><view class="class-grid data-v-b49079d4"><block wx:for="{{classList}}" wx:for-item="item" wx:for-index="__i1__" wx:key="_id"><view data-event-opts="{{[['tap',[['selectClass',['$0'],[[['classList','_id',item._id,'_id']]]]]]]}}" class="{{['class-option','data-v-b49079d4',(selectedClassId===item._id)?'selected':'']}}" bindtap="__e"><text class="class-name data-v-b49079d4">{{item.name}}</text><text class="class-count data-v-b49079d4">{{item.studentCount+"人"}}</text></view></block></view></view><view class="card data-v-b49079d4"><view class="card-title data-v-b49079d4">作业标题</view><input class="form-input data-v-b49079d4" placeholder="请输入作业标题" data-event-opts="{{[['input',[['__set_model',['','homeworkTitle','$event',[]]],['onTitleInput',['$event']]]]]}}" value="{{homeworkTitle}}" bindinput="__e"/></view><block wx:if="{{homeworkType==='voice'}}"><view class="card data-v-b49079d4"><view class="card-title data-v-b49079d4">跟读内容（每行一句）</view><textarea class="form-textarea data-v-b49079d4" placeholder="请输入要跟读的内容" data-event-opts="{{[['input',[['__set_model',['','homeworkContent','$event',[]]],['onContentInput',['$event']]]]]}}" value="{{homeworkContent}}" bindinput="__e"></textarea><block wx:if="{{$root.g0>0}}"><text class="form-hint data-v-b49079d4">{{"已输入 "+$root.g1+" 句"}}</text></block></view></block><block wx:if="{{$root.g2}}"><view class="card data-v-b49079d4"><view class="card-header-row data-v-b49079d4"><view class="card-title data-v-b49079d4">已选文章</view><view data-event-opts="{{[['tap',[['goToLibrary',['$event']]]]]}}" class="card-action data-v-b49079d4" bindtap="__e">+ 添加</view></view><block wx:if="{{$root.g3>0}}"><view class="article-list data-v-b49079d4"><block wx:for="{{selectedArticleDetails}}" wx:for-item="item" wx:for-index="__i2__" wx:key="_id"><view class="article-item data-v-b49079d4"><text class="article-icon data-v-b49079d4">📄</text><view class="article-info data-v-b49079d4"><text class="article-title data-v-b49079d4">{{item.title}}</text><text class="article-meta data-v-b49079d4">{{item.wordCount+"词"}}</text></view></view></block></view></block><block wx:if="{{$root.g4===0}}"><view class="empty-articles data-v-b49079d4"><text class="empty-text data-v-b49079d4">未选择文章</text><view data-event-opts="{{[['tap',[['goToLibrary',['$event']]]]]}}" class="empty-btn data-v-b49079d4" bindtap="__e">去资料库选择</view></view></block></view></block><view class="bottom-btns data-v-b49079d4"><view data-event-opts="{{[['tap',[['prevStep',['$event']]]]]}}" class="btn-secondary data-v-b49079d4" bindtap="__e">上一步</view><view data-event-opts="{{[['tap',[['nextStep',['$event']]]]]}}" class="btn-primary data-v-b49079d4" bindtap="__e">下一步</view></view></view></block><block wx:if="{{currentStep===3}}"><view class="step-content data-v-b49079d4"><view class="card data-v-b49079d4"><view class="card-title data-v-b49079d4">设置截止时间</view><picker mode="date" value="{{deadline}}" start="{{minDate}}" data-event-opts="{{[['change',[['onDateChange',['$event']]]]]}}" bindchange="__e" class="data-v-b49079d4"><view class="date-picker data-v-b49079d4"><text class="{{['date-text','data-v-b49079d4',(!deadline)?'placeholder':'']}}">{{deadline||'请选择日期'}}</text><text class="date-arrow data-v-b49079d4">›</text></view></picker></view><view class="card summary-card data-v-b49079d4"><view class="card-title data-v-b49079d4">作业预览</view><view class="summary-item data-v-b49079d4"><text class="summary-label data-v-b49079d4">类型</text><text class="summary-value data-v-b49079d4">{{homeworkType==='voice'?'语音朗读':'单词带背'}}</text></view><view class="summary-item data-v-b49079d4"><text class="summary-label data-v-b49079d4">班级</text><text class="summary-value data-v-b49079d4">{{selectedClassName}}</text></view><view class="summary-item data-v-b49079d4"><text class="summary-label data-v-b49079d4">标题</text><text class="summary-value data-v-b49079d4">{{homeworkTitle}}</text></view><block wx:if="{{$root.g5>0}}"><view class="summary-item data-v-b49079d4"><text class="summary-label data-v-b49079d4">内容</text><text class="summary-value data-v-b49079d4">{{$root.g6+"句"}}</text></view></block></view><view class="bottom-btns data-v-b49079d4"><view data-event-opts="{{[['tap',[['prevStep',['$event']]]]]}}" class="btn-secondary data-v-b49079d4" bindtap="__e">上一步</view><view data-event-opts="{{[['tap',[['publishHomework',['$event']]]]]}}" class="btn-primary data-v-b49079d4" bindtap="__e">发布作业</view></view></view></block></view>