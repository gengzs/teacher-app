<view class="container data-v-2cad9976"><view class="card data-v-2cad9976"><view class="homework-header data-v-2cad9976"><view class="{{['homework-icon','data-v-2cad9976',homeworkInfo.type]}}"><text class="data-v-2cad9976">{{homeworkInfo.type==='voice'?'🎤':'📖'}}</text></view><view class="homework-info data-v-2cad9976"><text class="homework-title data-v-2cad9976">{{homeworkInfo.title}}</text><text class="homework-meta data-v-2cad9976">{{homeworkInfo.className+" · "+homeworkInfo.deadline}}</text></view><view class="{{['homework-status','data-v-2cad9976',homeworkInfo.status]}}"><text class="data-v-2cad9976">{{homeworkInfo.status==='ongoing'?'进行中':'已结束'}}</text></view></view></view><block wx:if="{{homeworkInfo.type==='voice'}}"><view class="card data-v-2cad9976"><view class="card-title data-v-2cad9976">跟读内容</view><view class="content-preview data-v-2cad9976"><text class="data-v-2cad9976">{{homeworkInfo.content}}</text></view></view></block><view class="card progress-card data-v-2cad9976"><view class="progress-header data-v-2cad9976"><text class="progress-title data-v-2cad9976">提交情况</text><text class="progress-count data-v-2cad9976">{{homeworkInfo.submitCount+"/"+homeworkInfo.totalCount}}</text></view><view class="progress-bar-wrapper data-v-2cad9976"><view class="progress-bar data-v-2cad9976"><view class="progress-fill data-v-2cad9976" style="{{'width:'+(homeworkInfo.submitCount/homeworkInfo.totalCount*100+'%')+';'}}"></view></view><text class="progress-percent data-v-2cad9976">{{$root.g0+"%"}}</text></view></view><view class="card data-v-2cad9976"><view class="card-title data-v-2cad9976">学生列表</view><view class="student-list data-v-2cad9976"><block wx:for="{{submissions}}" wx:for-item="item" wx:for-index="__i0__" wx:key="studentId"><view data-event-opts="{{[['tap',[['viewSubmission',['$0'],[[['submissions','studentId',item.studentId]]]]]]]}}" class="student-item data-v-2cad9976" bindtap="__e"><view class="{{['student-avatar','data-v-2cad9976',item.status]}}"><text class="data-v-2cad9976">{{item.studentName[0]}}</text></view><view class="student-info data-v-2cad9976"><text class="student-name data-v-2cad9976">{{item.studentName}}</text><block wx:if="{{item.status==='completed'}}"><text class="submit-time data-v-2cad9976">{{"提交于 "+item.submitTime}}</text></block><block wx:if="{{item.status==='pending'}}"><text class="submit-time pending data-v-2cad9976">待提交</text></block></view><block wx:if="{{item.status==='completed'}}"><view class="student-score data-v-2cad9976"><text class="score-num data-v-2cad9976">{{item.score}}</text><text class="score-label data-v-2cad9976">分</text></view></block><block wx:if="{{item.status==='completed'}}"><text class="play-icon data-v-2cad9976">▶</text></block></view></block></view></view></view>