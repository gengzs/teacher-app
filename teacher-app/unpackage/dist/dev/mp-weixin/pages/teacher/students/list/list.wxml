<view class="container data-v-8c027884"><view class="search-bar data-v-8c027884"><input class="search-input data-v-8c027884" placeholder="搜索学生姓名或班级" data-event-opts="{{[['input',[['__set_model',['','searchKey','$event',[]]],['onSearch',['$event']]]]]}}" value="{{searchKey}}" bindinput="__e"/><view class="search-icon data-v-8c027884">🔍</view></view><view class="filter-bar data-v-8c027884"><view data-event-opts="{{[['tap',[['toggleShowLeft',['$event']]]]]}}" class="filter-toggle data-v-8c027884" bindtap="__e"><text class="{{['data-v-8c027884',(showLeftStudents)?'active':'']}}">{{''+(showLeftStudents?'全部学生':'仅在班')+''}}</text></view><text class="filter-count data-v-8c027884">{{$root.g0+"名学生"}}</text></view><block wx:if="{{$root.g1>0}}"><view class="student-list data-v-8c027884"><block wx:for="{{filteredStudents}}" wx:for-item="item" wx:for-index="__i0__" wx:key="_id"><view class="{{['student-item','data-v-8c027884',(item.status==='inactive')?'left':'']}}"><view class="{{['student-avatar','data-v-8c027884',(item.status==='inactive')?'left':'']}}">{{''+item.name[0]+''}}</view><view data-event-opts="{{[['tap',[['goToStudentDetail',['$0','$1'],[[['filteredStudents','_id',item._id,'_id']],[['filteredStudents','_id',item._id,'name']]]]]]]}}" class="student-info data-v-8c027884" bindtap="__e"><text class="student-name data-v-8c027884">{{item.name}}</text><text class="student-class data-v-8c027884">{{item.className}}</text></view><view class="student-status data-v-8c027884"><block wx:if="{{item.status==='inactive'}}"><text class="status-tag left data-v-8c027884">已离班</text></block><block wx:if="{{item.status==='active'&&item.joinSource==='invite'}}"><text class="status-tag invite data-v-8c027884">邀请加入</text></block><block wx:if="{{item.status==='active'&&item.joinSource==='manual'}}"><text class="status-tag manual data-v-8c027884">手动添加</text></block></view><block wx:if="{{item.status==='active'}}"><view class="student-action data-v-8c027884"><view data-event-opts="{{[['tap',[['removeStudent',['$0','$1','$2'],[[['filteredStudents','_id',item._id,'_id']],[['filteredStudents','_id',item._id,'name']],[['filteredStudents','_id',item._id,'classId']]]]]]]}}" class="action-btn remove data-v-8c027884" bindtap="__e">移除</view></view></block></view></block></view></block><block wx:if="{{$root.g2}}"><view class="empty-state data-v-8c027884"><text class="icon data-v-8c027884">👨‍🎓</text><text class="text data-v-8c027884">{{searchKey?'未找到匹配的学生':'暂无学生'}}</text><view data-event-opts="{{[['tap',[['goToClassList',['$event']]]]]}}" class="empty-btn data-v-8c027884" bindtap="__e"> 去班级添加学生 </view></view></block><block wx:if="{{loading}}"><view class="loading-state data-v-8c027884"><text class="data-v-8c027884">加载中...</text></view></block></view>